{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "favoriteSlugs": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "Article": {
      "title": "Article",
      "description": "Blog article content.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "coverImage": { "type": "string" },
        "category": { "type": "string" },
        "published": { "type": "boolean" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "authorId"]
    },
    "Product": {
      "title": "Product",
      "description": "Shop product (preset or guide).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["preset", "guide"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "category"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings like statistics.",
      "type": "object",
      "properties": {
        "igFollowers": { "type": "string" },
        "monthlyReach": { "type": "string" },
        "uniqueUsers": { "type": "string" },
        "engagementRate": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["igFollowers", "monthlyReach", "uniqueUsers", "engagementRate"]
    },
    "Lead": {
      "title": "Lead",
      "description": "B2B Lead from Media Kit download.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "company", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order from the shop.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "email", "total", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount code for the shop.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "value", "active"]
    },
    "Log": {
      "title": "Log",
      "description": "System activity log.",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["action", "userEmail", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User document containing their role and favorites."
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Blog articles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Shop products."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings (e.g. stats)."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "B2B Leads."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    },
    "/coupons/{couponId}": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Discount coupons."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Activity logs."
    }
  }
}
