# ============================================================
# TRAVELLINIWITHUS — Variabili d'ambiente
# ============================================================
# Copia in `.env.local` e inserisci i valori reali solo in fase pre-deploy.
# Questo file È committato — non inserire mai valori reali qui.
#
# Regola operativa:
#   Il codice è scritto con guard clause: ogni integrazione
#   si auto-disabilita silenziosamente se la chiave manca.
#   Il sito funziona anche con zero chiavi configurate.
#
# Ordine nel file = ordine di attivazione consigliato a fine preparazione.
# ============================================================


# ============================================================
# APP (essenziale, già attive)
# ============================================================

# Locale: http://localhost:3000 | Prod: https://travelliniwithus.it
APP_URL=http://localhost:3000

# Frontend/staging autorizzati dal CORS del server in produzione.
FRONTEND_URL=https://travelliniwithus.it
STAGING_URL=

# Override opzionale del link PDF inviato per il media kit.
# Se vuoto: usa APP_URL/media-kit.pdf in locale, travelliniwithus.it/media-kit.pdf in fallback.
MEDIA_KIT_URL=

# Email mittente transazionale (verificato su Resend)
MAIL_FROM="Travelliniwithus <hello@travelliniwithus.it>"

# Email destinataria lead interna (form collaborazioni/media kit/contatti)
MAIL_TO_OWNER=hello@travelliniwithus.it

# Firebase project ID (opzionale — per script admin CI e validazione predeploy).
# Se presente: predeploy verifica che combaci col projectId di firebase-applet-config.json.
FIREBASE_PROJECT_ID=gen-lang-client-0138696306


# ============================================================
# DEV FLAGS
# ============================================================

# true in locale per bypassare Stripe con checkout mock (test flow completo senza chiavi)
ALLOW_MOCK_CHECKOUT=true


# ============================================================
# ESSENZIALI GO-LIVE (attivare prima del deploy pubblico)
# ============================================================

# --- STRIPE — checkout shop (essenziale se shop attivo) ---
# Dashboard: https://dashboard.stripe.com/apikeys
# Test mode per sviluppo, live solo in prod
# Webhook endpoint da configurare: https://<api-domain>/api/webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- RESEND — email transazionale (essenziale per lead notifications + order receipts) ---
# Dashboard: https://resend.com/api-keys
# Domain verification richiesta: https://resend.com/domains (verificare travelliniwithus.it)
RESEND_API_KEY=

# --- BREVO — newsletter + audience (essenziale per lead capture) ---
# Dashboard: https://app.brevo.com/settings/keys/api
# Creare prima la lista DOI (Double Opt-In), poi copiare l'ID qui.
# Quando la lista supera ~1000 iscritti: valutare migrazione a Kit (convertkit.com) per workflow creator.
BREVO_API_KEY=
BREVO_LIST_ID=

# --- SENTRY — error tracking + performance monitoring (essenziale pre-launch) ---
# Dashboard: https://sentry.io/settings/projects/
# DSN separati client/server consigliato (usa progetti distinti per isolare i volumi).
VITE_SENTRY_DSN=
SENTRY_DSN=


# ============================================================
# MARKETING / ANALYTICS (attivare dopo go-live, per remarketing + funnel)
# ============================================================

# --- GA4 — Google Analytics 4 (remarketing + event tracking + audience export a Google Ads) ---
# Dashboard: https://analytics.google.com/ | Misurazione: GA4 property
VITE_GA_ID=

# --- Meta Pixel — remarketing IG/FB ---
# Dashboard: https://business.facebook.com/events_manager
VITE_META_PIXEL_ID=

# --- TikTok Pixel — remarketing TikTok ---
# Dashboard: https://ads.tiktok.com/i18n/events_manager
VITE_TIKTOK_PIXEL_ID=

# --- Plausible (opzionale, analytics privacy-first cookie-less, dashboard clean) ---
# Dashboard: https://plausible.io | Settings: plausible.io/:domain/settings
# Lasciare vuoto se vuoi GA4 only. Attivare se vuoi dashboard semplice senza cookie banner layer.
VITE_PLAUSIBLE_DOMAIN=


# ============================================================
# FEATURE SPECIFIC
# ============================================================

# --- MAPBOX — tiles produzione per mappa interattiva ---
# Dashboard: https://account.mapbox.com/access-tokens
# Free tier: 50k loads/mese. Token pubblico con restrict URL consigliato.
VITE_MAPBOX_TOKEN=

# --- GEMINI AI — verification/enrichment articoli (ADMIN only via /api/ai/*) ---
# Dashboard: https://aistudio.google.com/apikey
# Endpoint server-side con rate limit 5/min e guard auth. Low priority, feature editorial.
GEMINI_API_KEY=
