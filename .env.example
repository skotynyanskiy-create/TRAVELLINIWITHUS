# ============================================================
# TRAVELLINIWITHUS — Variabili d'ambiente richieste
# ============================================================
# Copia in .env e inserisci i valori reali.
# Questo file È committato — non inserire mai valori reali qui.
# ============================================================

# --- STRIPE ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- APP ---
# Locale: http://localhost:3000 | Produzione: https://travelliniwithus.it
APP_URL=http://localhost:3000

# --- GEMINI AI ---
# Dashboard: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# --- MAPBOX ---
# Dashboard: https://account.mapbox.com/access-tokens
VITE_MAPBOX_TOKEN=...

# --- DEV FLAGS ---
# true in locale per bypassare Stripe con checkout mock
ALLOW_MOCK_CHECKOUT=true
