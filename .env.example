# ============================================================
# TRAVELLINIWITHUS — Variabili d'ambiente
# ============================================================
# Copia in `.env` e inserisci i valori reali solo in fase pre-deploy.
# Questo file È committato — non inserire mai valori reali qui.
#
# Regola operativa (da memoria progetto):
#   Il codice è scritto con guard clause: ogni integrazione
#   si auto-disabilita silenziosamente se la chiave manca.
#   Il sito funziona anche con zero chiavi configurate.
# ============================================================

# --- APP ---
# Locale: http://localhost:3000 | Prod: https://travelliniwithus.it
APP_URL=http://localhost:3000
# Override opzionale del link PDF inviato per il media kit.
# Se vuoto, usa APP_URL/media-kit.pdf in locale e travelliniwithus.it/media-kit.pdf in fallback.
MEDIA_KIT_URL=
# Email mittente transazionale (verificato su Resend)
MAIL_FROM="Travelliniwithus <hello@travelliniwithus.it>"
# Email destinataria lead interna
MAIL_TO_OWNER=hello@travelliniwithus.it

# --- STRIPE ---
# Dashboard: https://dashboard.stripe.com/apikeys
# Test mode per sviluppo, live solo in prod
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID del piano Club ricorrente (creato in Stripe)
STRIPE_CLUB_PRICE_ID=price_...

# --- RESEND (email transazionale) ---
# Dashboard: https://resend.com/api-keys
# Domain verification richiesta: https://resend.com/domains
RESEND_API_KEY=

# --- BREVO (newsletter + audience) ---
# Dashboard: https://app.brevo.com/settings/keys/api
# Lista DOI ID (crea prima la lista in Brevo)
BREVO_API_KEY=
BREVO_LIST_ID=

# --- OPENAI (AI semantic search) ---
# Dashboard: https://platform.openai.com/api-keys
# Modello scelto: text-embedding-3-small (~$0.02/1M token)
OPENAI_API_KEY=

# --- SENTRY (error tracking) ---
# Dashboard: https://sentry.io/settings/projects/
# DSN separati client/server consigliato
VITE_SENTRY_DSN=
SENTRY_DSN=

# --- ANALYTICS / PIXEL ---
# GA4: https://analytics.google.com/
VITE_GA_ID=
# Meta Pixel: https://business.facebook.com/events_manager
VITE_META_PIXEL_ID=
# TikTok Pixel: https://ads.tiktok.com/i18n/events_manager
VITE_TIKTOK_PIXEL_ID=

# --- MAPBOX ---
# Dashboard: https://account.mapbox.com/access-tokens
VITE_MAPBOX_TOKEN=

# --- GEMINI AI (legacy, valutare se dismettere) ---
# Dashboard: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- DEV FLAGS ---
# true in locale per bypassare Stripe con checkout mock
ALLOW_MOCK_CHECKOUT=true
