# Canonical public URL
APP_URL="http://localhost:3000"

# Server checkout
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
ALLOW_MOCK_CHECKOUT="true"

# Newsletter sync
BREVO_API_KEY=""

# Optional client integrations
VITE_GEMINI_API_KEY=""

# Demo content is disabled by default in production.
# Enable only in local or staging environments where demo content is intentional.
VITE_ENABLE_DEMO_CONTENT="false"
ENABLE_DEMO_CONTENT="false"

# Optional client error forwarding override.
# In production the frontend already sends monitoring events by default.
VITE_ENABLE_REMOTE_MONITORING="false"

# Optional server port override
PORT="3000"
