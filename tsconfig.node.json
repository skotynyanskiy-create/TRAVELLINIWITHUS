{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx"
  },
  "include": ["server.ts", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
