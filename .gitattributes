# Normalizzazione cross-platform.
# LF ovunque, Git gestisce la conversione in checkout.
* text=auto eol=lf

# Script shell e config sempre LF
*.sh           text eol=lf
*.mjs          text eol=lf
*.cjs          text eol=lf
*.js           text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.css          text eol=lf
*.html         text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf

# File Windows-only (se presenti) forzano CRLF
*.bat          text eol=crlf
*.ps1          text eol=crlf

# Binari — nessuna normalizzazione, nessun diff rumoroso
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.avif         binary
*.ico          binary
*.svg          text eol=lf
*.pdf          binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.otf          binary
*.mp4          binary
*.webm         binary
*.zip          binary
