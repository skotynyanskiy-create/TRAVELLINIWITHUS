{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "generate:media-kit": "tsx scripts/generate-media-kit.tsx",
    "build": "npm run generate:media-kit && node scripts/generate-sitemap.js && vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "test": "vitest run",
    "e2e": "playwright test",
    "audit:ui": "node scripts/check-ui.mjs",
    "audit:firebase": "node scripts/check-firebase.mjs",
    "audit:stripe": "node scripts/check-stripe.mjs",
    "audit:agents": "node scripts/audit-agent-stack.mjs",
    "audit:visual": "playwright test e2e/visual-quality.spec.ts",
    "audit:quality": "npm run typecheck && npm run lint && npm run test && npm run build && npm run audit:ui && npm run audit:firebase && npm run audit:stripe && npm run audit:agents && npm run audit:visual",
    "audit:all": "npm run audit:ui && npm run audit:firebase && npm run audit:stripe",
    "sync:agents": "node scripts/sync-agent-skills.mjs",
    "scaffold:page": "node scripts/scaffold-page.mjs",
    "predeploy": "node scripts/predeploy.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-pdf/renderer": "^4.3.1",
    "@stripe/stripe-js": "^8.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@types/mapbox-gl": "^3.4.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.546.0",
    "mapbox-gl": "^3.20.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.1.1",
    "react-helmet-async": "^3.0.0",
    "react-intersection-observer": "^10.0.3",
    "react-is": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.13.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.4.1",
    "vite": "^6.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0",
    "*.{ts,tsx,css,md,json}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "node-cache": "^5.1.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "workbox-window": "^7.4.0"
  }
}
