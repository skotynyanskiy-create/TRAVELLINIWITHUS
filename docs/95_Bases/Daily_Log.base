filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("40_Daily")'
properties:
  file.name:
    displayName: Day
  status:
    displayName: Status
  owner:
    displayName: Owner
  file.mtime:
    displayName: Updated
views:
  - type: table
    name: Recent Daily
    order:
      - file.name
