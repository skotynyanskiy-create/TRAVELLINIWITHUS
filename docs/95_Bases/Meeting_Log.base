filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("30_Meetings")'
properties:
  file.name:
    displayName: Meeting
  status:
    displayName: Status
  owner:
    displayName: Owner
  file.mtime:
    displayName: Updated
views:
  - type: table
    name: Latest Meetings
    order:
      - file.mtime
